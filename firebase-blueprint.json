{
  "entities": {
    "Invoice": {
      "title": "Invoice",
      "description": "Financial document representing a request for payment.",
      "type": "object",
      "properties": {
        "taxInvoice": { "type": "string" },
        "invoiceDate": { "type": "string" },
        "customerPO": { "type": "string" },
        "salesOrderNo": { "type": "string" },
        "deliveryNoteNo": { "type": "string" },
        "customerContact": { "type": "string" },
        "customerCode": { "type": "string" },
        "customerName": { "type": "string" },
        "schoolName": { "type": "string" },
        "streetAddress": { "type": "string" },
        "suburb": { "type": "string" },
        "district": { "type": "string" },
        "customerAddressLine1": { "type": "string" },
        "customerAddressLine2": { "type": "string" },
        "postalCode": { "type": "string" },
        "vatNo": { "type": "string" },
        "deliveryCustomerName": { "type": "string" },
        "deliveryAddressLine1": { "type": "string" },
        "deliveryAddressLine2": { "type": "string" },
        "deliveryRegion": { "type": "string" },
        "lineItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stockCode": { "type": "string" },
              "description": { "type": "string" },
              "qty": { "type": "number" },
              "unitPrice": { "type": "number" },
              "disc": { "type": "number" },
              "value": { "type": "number" }
            }
          }
        },
        "subTotal": { "type": "number" },
        "vatAmount": { "type": "number" },
        "amountIncl": { "type": "number" },
        "freight": { "type": "number" },
        "totalDue": { "type": "number" },
        "accountTerms": { "type": "string" },
        "companyName": { "type": "string" },
        "companyAddressLine1": { "type": "string" },
        "companyAddressLine2": { "type": "string" },
        "companyPhysicalAddress": { "type": "string" },
        "companyIndustrialPark": { "type": "string" },
        "telephone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "registrationNo": { "type": "string" },
        "companyVatNo": { "type": "string" },
        "bankName": { "type": "string" },
        "branch": { "type": "string" },
        "account": { "type": "string" },
        "swift": { "type": "string" },
        "page": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "darft", "proposed", "assembled", "assembly", "on-route", "on route", "on_route", "delivered", "completed", "complete", "partially_complete", "partially complete"] },
        "deliveredDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taxInvoice", "userId", "totalDue", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer entity for CRM.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "Truck": {
      "title": "Truck",
      "description": "Fleet vehicle entity.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "licensePlate": { "type": "string" },
        "maxValue": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "licensePlate", "userId"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Delivery schedule for a specific truck and day.",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "truckId": { "type": "string" },
        "invoiceIds": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["day", "truckId", "invoiceIds", "userId"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A delivery trip with geographical data and related invoices.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "truckId": { "type": "string" },
        "status": { "type": "string", "enum": ["proposed", "assembled", "on-route", "partially-completed", "completed", "invoiced"] },
        "invoiceIds": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "truckId", "status", "userId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User application settings, including warehouse location.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "warehouseAddress": { "type": "string" },
        "warehouseLat": { "type": "number" },
        "warehouseLng": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Team collaborator invited by the account owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["viewer", "editor"] },
        "note": { "type": "string" },
        "inviteCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "firstName", "lastName", "email", "role", "inviteCode", "status", "createdAt", "updatedAt"]
    },
    "KnockdownItem": {
      "title": "KnockdownItem",
      "description": "Stock item with linked parts.",
      "type": "object",
      "properties": {
        "stockCode": { "type": "string" },
        "description": { "type": "string" },
        "qty": { "type": "number" },
        "displayName": { "type": "string" },
        "type": { "type": "string", "enum": ["knockdown", "assembled", "pre-assembled"] },
        "userId": { "type": "string" },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "partCode": { "type": "string" },
              "description": { "type": "string" },
              "qty": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["stockCode", "description", "qty", "displayName", "userId"]
    },
    "JointStockTake": {
      "title": "JointStockTake",
      "description": "Stock take record of multiple counted items.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedByUserId": { "type": "string" },
        "userId": { "type": "string" },
        "submittedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "partially_completed", "completed"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stockCode": { "type": "string" },
              "description": { "type": "string" },
              "isPart": { "type": "boolean" },
              "parentItem": { "type": "string" },
              "countedQty": { "type": "number" },
              "expectedQty": { "type": "number" },
              "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
            }
          }
        }
      },
      "required": ["code", "submittedBy", "submittedByUserId", "userId", "submittedAt", "status", "items"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "An item in the approved physical inventory.",
      "type": "object",
      "properties": {
        "stockCode": { "type": "string" },
        "description": { "type": "string" },
        "displayName": { "type": "string" },
        "qty": { "type": "number" },
        "isPart": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["stockCode", "description", "displayName", "qty", "userId"]
    },
    "Product": {
      "title": "Product",
      "description": "A unique catalog product linked to the user, persisted from invoice line items.",
      "type": "object",
      "properties": {
        "stockCode": { "type": "string" },
        "description": { "type": "string" },
        "unitPrice": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["stockCode", "description", "unitPrice", "userId"]
    }
  },
  "firestore": {
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of invoices."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients."
    },
    "/trucks/{truckId}": {
      "schema": "Truck",
      "description": "Collection of trucks."
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Collection of delivery schedules."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Collection of trips."
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "User specific settings."
    },
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members."
    },
    "/knockdown_items/{itemId}": {
      "schema": "KnockdownItem",
      "description": "Collection of knockdown items and parts."
    },
    "/stock_takes/{takeId}": {
      "schema": "JointStockTake",
      "description": "Collection of joint stock takes."
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Collection of approved inventory items."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of catalog products derived from invoice line items."
    }
  }
}
