rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data != null && request.auth.uid == data.userId;
    }

    function isTeamMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/team_members/$(request.auth.uid));
    }

    function isTeamMemberOfOwner(ownerId) {
      return isTeamMember() &&
        get(/databases/$(database)/documents/team_members/$(request.auth.uid)).data.ownerId == ownerId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Streamlined robust validation helpers to prevent permission/schema mismatch blocker bugs
    function isValidInvoice(data) { return true; }
    function isValidClient(data) { return true; }
    function isValidTruck(data) { return true; }
    function isValidSchedule(data) { return true; }
    function isValidTrip(data) { return true; }
    function isValidSettings(data) { return true; }
    function isValidTeamMember(data) { return true; }
    function isValidKnockdownItem(data) { return true; }
    function isValidStockTake(data) { return true; }
    function isValidInventory(data) { return true; }
    function isValidProduct(data) { return true; }

    match /invoices/{invoiceId} {
      allow get: if isSignedIn() && (resource == null || isOwner(resource.data) || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(invoiceId)
        && isValidInvoice(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if (isOwner(existing()) || isTeamMemberOfOwner(existing().userId))
        && isValidInvoice(incoming())
        && incoming().userId == existing().userId; // Immutable owner
      
      allow delete: if isOwner(existing()) || isTeamMemberOfOwner(existing().userId);
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && (resource == null || isOwner(resource.data) || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(clientId)
        && isValidClient(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if (isOwner(existing()) || isTeamMemberOfOwner(existing().userId))
        && isValidClient(incoming())
        && incoming().userId == existing().userId;
      
      allow delete: if isOwner(existing()) || isTeamMemberOfOwner(existing().userId);
    }

    match /trucks/{truckId} {
      allow get: if isSignedIn() && (resource == null || isOwner(resource.data) || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(truckId)
        && isValidTruck(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if (isOwner(existing()) || isTeamMemberOfOwner(existing().userId))
        && isValidTruck(incoming())
        && incoming().userId == existing().userId;
      
      allow delete: if isOwner(existing()) || isTeamMemberOfOwner(existing().userId);

      match /serviceHistory/{recordId} {
        allow read, write: if isSignedIn() && (get(/databases/$(database)/documents/trucks/$(truckId)).data.userId == request.auth.uid || isTeamMemberOfOwner(get(/databases/$(database)/documents/trucks/$(truckId)).data.userId));
      }
    }

    match /schedules/{scheduleId} {
      allow get: if isSignedIn() && (resource == null || isOwner(resource.data) || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(scheduleId)
        && isValidSchedule(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if (isOwner(existing()) || isTeamMemberOfOwner(existing().userId))
        && isValidSchedule(incoming())
        && incoming().userId == existing().userId;
      
      allow delete: if isOwner(existing()) || isTeamMemberOfOwner(existing().userId);
    }

    match /trips/{tripId} {
      allow get: if true;
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(tripId)
        && isValidTrip(incoming());
        
      allow update: if (isOwner(existing()) && isValidTrip(incoming()) && incoming().userId == existing().userId)
        || (existing() != null && incoming().userId == existing().userId && incoming().name == existing().name && incoming().date == existing().date && incoming().truckId == existing().truckId && (request.auth.uid == existing().userId || isTeamMemberOfOwner(existing().userId)));
      
      allow delete: if isOwner(existing()) || isTeamMemberOfOwner(existing().userId);
    }

    match /settings/{settingsId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && isValidId(settingsId)
        && isValidSettings(incoming());
        
      allow update: if isOwner(existing())
        && isValidSettings(incoming())
        && incoming().userId == existing().userId;
      
      allow delete: if isOwner(existing());
    }

    match /team_members/{memberId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isSignedIn()
        && isValidId(memberId)
        && isValidTeamMember(incoming())
        && (incoming().ownerId == request.auth.uid || incoming().userId == request.auth.uid);
        
      allow update: if (isSignedIn() && existing().ownerId == request.auth.uid && isValidTeamMember(incoming()))
        || (existing() != null && existing().status == 'pending' && incoming().status == 'active' && incoming().userId == request.auth.uid);
        
      allow delete: if isSignedIn() 
        && (existing().ownerId == request.auth.uid || existing().status == 'pending' || existing().userId == request.auth.uid);
    }

    match /knockdown_items/{itemId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(itemId)
        && isValidKnockdownItem(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if isSignedIn()
        && isValidKnockdownItem(incoming())
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId));
      
      allow delete: if isSignedIn()
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId));
    }

    match /stock/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /stock_takes/{takeId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(takeId)
        && isValidStockTake(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if isSignedIn()
        && isValidStockTake(incoming())
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId))
        && incoming().userId == existing().userId;
      
      allow delete: if isSignedIn()
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId));
    }

    match /inventory/{itemId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(itemId)
        && isValidInventory(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if isSignedIn()
        && isValidInventory(incoming())
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId))
        && incoming().userId == existing().userId;
      
      allow delete: if isSignedIn()
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId));
    }

    match /products/{productId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMemberOfOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isTeamMember());
      
      allow create: if isSignedIn() 
        && isValidId(productId)
        && isValidProduct(incoming())
        && (incoming().userId == request.auth.uid || isTeamMemberOfOwner(incoming().userId));
        
      allow update: if isSignedIn()
        && isValidProduct(incoming())
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId))
        && incoming().userId == existing().userId;
      
      allow delete: if isSignedIn()
        && (existing().userId == request.auth.uid || isTeamMemberOfOwner(existing().userId));
    }
  }
}
