# XAI_API_KEY: Required for Invoice extraction via xAI (Grok).
# This should be stored in Firebase Functions as a secret.
XAI_API_KEY="your_xai_api_key_here"

# OPENAI_API_KEY: Required for Invoice extraction via OpenAI API.
# This should be stored in Firebase Functions as a secret.
OPENAI_API_KEY="your_openai_api_key_here"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PUSHOVER_APP_TOKEN: The shared Pushover App Token required for sending notifications
PUSHOVER_APP_TOKEN=

# GOOGLE_APPLICATION_CREDENTIALS: Absolute path to a Firebase Admin service-account
# key JSON, required ONLY for local dev so the admin endpoints (team-member
# management, test-pushover) can verify ID tokens with checkRevoked. In Cloud
# Functions this is auto-provided by the runtime. Use forward slashes on Windows.
# GOOGLE_APPLICATION_CREDENTIALS="C:/secrets/invoiceforge-fd8dc-adminsdk.json"



# GOOGLE_OAUTH_CLIENT_ID: Public OAuth 2.0 Web Client ID used by the browser
# (Google Identity Services token client) to request Google Calendar access for
# team-member trip sync. Find it in Google Cloud Console > APIs & Services >
# Credentials > OAuth 2.0 Client IDs > Web client.
GOOGLE_OAUTH_CLIENT_ID=
