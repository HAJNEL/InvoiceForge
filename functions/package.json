{
  "name": "functions",
  "description": "Cloud Functions for InvoiceForge (wraps the Express backend)",
  "main": "index.js",
  "scripts": {
    "build": "npm --prefix .. run build:functions",
    "serve": "npm run build && firebase emulators:start --only functions,hosting",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@llamaindex/llama-cloud": "^2.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.5.0",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
